<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<HBox prefHeight="800.0" prefWidth="1000.0" styleClass="main-container" stylesheets="@modern-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mahbub.codesharejfx.UserPanelController">
   <children>
      <VBox prefHeight="800.0" prefWidth="419.0" spacing="20.0" styleClass="sidebar">
         <children>
            <Label styleClass="logo-text" text="CODE SHARE" />

            <VBox spacing="10.0" styleClass="card">
               <Text styleClass="section-header" text="My Status" />
               <HBox alignment="CENTER_LEFT" spacing="10">
                  <Circle fx:id="activeStatus" fill="RED" radius="5" />
                  <Text fx:id="CurrentlyJoinedRoom" fill="WHITE" styleClass="status-text" text="Joined Room : None" />
               </HBox>
            </VBox>

            <VBox spacing="10.0" styleClass="card">
               <Label styleClass="section-header" text="Room Management" textFill="#17b9b9" />
               <TextField fx:id="myRoomID" promptText="Your Room ID" styleClass="modern-input" />
               <Button maxWidth="Infinity" onAction="#CreateMyOwnRoom" styleClass="primary-button" text="Create Room" />

               <Separator styleClass="modern-separator" />

               <TextField fx:id="joinRoomBox" promptText="Enter ID to Join" styleClass="modern-input" />
               <Button maxWidth="Infinity" onAction="#JoinRoom" styleClass="secondary-button" text="Join Room" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" onAction="#UploadCode" styleClass="action-button" text="Upload Snippet" />
            <Button maxWidth="Infinity" onAction="#GetCode" styleClass="action-button" text="Sync Code" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
         </padding>
      </VBox>

      <VBox prefHeight="800.0" prefWidth="549.0" spacing="15.0" styleClass="content-area" HBox.hgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label styleClass="editor-label" text="Editor" textFill="#12eaf2" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="ccppcompiler" onAction="#CompileCCpp" styleClass="compile-button" text="Run C/C++" />
               </children>
            </HBox>
            <TextArea fx:id="codeSnippet" promptText="// Paste your code here..." styleClass="modern-codebox" stylesheets="@modern-style.css" VBox.vgrow="ALWAYS" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</HBox>
